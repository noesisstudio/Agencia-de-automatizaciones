# PLANTILLA — NO pongas aquí tus claves reales.
# Copia este archivo a .env UNA VEZ:  cp .env.example .env
# Edita SOLO el archivo .env (el panel y la API leen .env, no este archivo).

APP_ENV=development
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Chatbot WhatsApp (Meta Cloud API)
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=openix_verify_token_seguro
META_APP_SECRET=
# Pruebas sin validar firma (1 = sí). En producción déjalo en 0 y usa APP_SECRET correcto.
# META_WEBHOOK_SKIP_SIGNATURE=0

# Empresa activa cuando llega un mensaje por WhatsApp
CHATBOT_TENANT_DEFAULT=mi-empresa

# Presupuesto WhatsApp (solo menú + catálogo JSON, sin IA)
# Catálogo por cliente: data/tenants/{id}/catalogo.json
# PRESUPUESTO_CATALOGO_PATH=/ruta/global/catalogo.json

# Tras reiniciar: scripts/post-reinicio.sh lee estas variables
# CHATBOT_PORT=8000
# NGROK_AUTOSTART=1
