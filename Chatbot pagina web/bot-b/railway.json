{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "variables": {
    "PORT": {
      "description": "Puerto de ejecución",
      "default": "3000"
    },
    "TENANT_ID": {
      "description": "ID del cliente",
      "default": "noesis"
    },
    "EMPRESA_NOMBRE": {
      "description": "Nombre de la empresa",
      "default": "Noesis"
    },
    "APP_ENV": {
      "description": "Entorno (production/development)",
      "default": "production"
    },
    "ALLOWED_ORIGINS": {
      "description": "CORS - Dominios permitidos",
      "value": "https://noesis.com,https://www.noesis.com"
    }
  }
}
