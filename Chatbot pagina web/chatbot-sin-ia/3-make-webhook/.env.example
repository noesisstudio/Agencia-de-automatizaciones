# Copiar a .env y rellenar con valores reales (nunca subir .env al repositorio)

# Token que Voiceflow envía en la cabecera X-Webhook-Secret
# Generar con: openssl rand -hex 32
WEBHOOK_SECRET=cambia_esto_por_un_secreto_seguro

# URL del webhook de Make.com
# Obtener en Make → Escenario → Módulo Webhooks → Copiar URL
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/XXXXXXXXXXXXXXXX

# Puerto (Railway lo asigna automáticamente — dejar vacío en local usará 3000)
PORT=3000
