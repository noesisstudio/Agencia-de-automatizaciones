# Copiar a .env y rellenar — nunca subir .env al repositorio

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service role key (no la anon key)

# ── Configuración del cliente (un .env por despliegue / por cliente) ─────────
TENANT_ID=nombre-cliente        # Identificador único del cliente (sin espacios)
EMPRESA_NOMBRE=Nombre Empresa   # Nombre que aparece en los emails y el bot

# ── Email (SMTP del propio cliente) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com        # O el servidor del cliente
SMTP_PORT=587
SMTP_USER=email@cliente.com
SMTP_PASS=contraseña_de_aplicacion   # En Gmail: cuenta → Seguridad → Contraseñas de app
EMAIL_EQUIPO=equipo@cliente.com      # A quién se notifica cuando llega un lead

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000                       # Railway lo asigna automáticamente
ALLOWED_ORIGINS=https://cliente.com,https://www.cliente.com
