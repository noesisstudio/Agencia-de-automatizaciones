{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FacturAI: ejecutar (API + pestaña automática)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "127.0.0.1", "--port", "8010"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "jinja": true,
      "justMyCode": true,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Uvicorn running on (https?://\\S+)",
        "uriFormat": "%s/pagina.html"
      }
    },
    {
      "name": "FacturAI: servidor (uvicorn, sin abrir pestaña)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "127.0.0.1", "--port", "8010"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "FacturAI: run.py (script local)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/run.py",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "justMyCode": true
    }
  ]
}
