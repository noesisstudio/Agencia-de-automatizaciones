APP_ENV=production

# ── Anthropic (OBLIGATORIO para extracción IA) ──────────────────────────────
# Consigue tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-PEGA_TU_CLAVE_REAL_AQUI
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Tu empresa (aparece en facturas y PDF) ───────────────────────────────────
MI_NIF_EMPRESA=B12345678
MI_NOMBRE_EMPRESA=Tu Empresa S.L.

# ── Google Sheets (opcional — exporta facturas automáticamente) ──────────────
# Copia el JSON de tu cuenta de servicio a backend/credentials/
# y pon el ID de tu hoja de cálculo aquí:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Facturas

# ── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/facturai.db

# ── Seguridad (OBLIGATORIO — cambia estos valores) ──────────────────────────
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_genera_con_python3_secrets
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── Admin inicial ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIA_ESTO_minimo_12_caracteres
ADMIN_EMAIL=tu@email.com

# ── Email SMTP (opcional — para enviar facturas por email) ───────────────────
# Gmail: smtp.gmail.com / 587 / tu correo / contraseña de aplicación
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ── Almacenamiento ──────────────────────────────────────────────────────────
PDF_STORAGE_PATH=./storage/invoices
UPLOAD_MAX_SIZE_MB=15

# ── SSO con portal Noesis (Supabase) ────────────────────────────────────────
# URL de tu proyecto Supabase (ya la tienes en supabase-config.js)
SUPABASE_URL=https://zhvytwqvbtsenzwrsysi.supabase.co
# JWT Secret: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=PEGA_TU_JWT_SECRET_DE_SUPABASE

# ── CORS (pon tu dominio de producción) ──────────────────────────────────────
# Incluye el dominio del portal para que el SSO funcione
CORS_ORIGINS=https://facturas.bynoesis.com,https://bynoesis.com,http://localhost:8010
