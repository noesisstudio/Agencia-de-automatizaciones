APP_ENV=development

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...          # OBLIGATORIO
ANTHROPIC_MODEL=claude-sonnet-4-6

MI_NIF_EMPRESA=
MI_NOMBRE_EMPRESA=

# --- Google Sheets (exportación automática de facturas) ---
# Lo más fácil: deja GOOGLE_SERVICE_ACCOUNT_JSON vacío y copia tu JSON de cuenta de
# servicio dentro de backend/credentials/ (ver backend/credentials/README.md).
# El ID de la hoja y el nombre de pestaña se pueden definir aquí O desde la app
# (Configuración → Exportar y Conexiones); lo de la app tiene prioridad.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Facturas

# Base de datos (SQLite local)
DATABASE_URL=sqlite:///./data/facturai.db
# OBLIGATORIO: genera con → python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=                           # OBLIGATORIO — no dejar vacío
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Admin inicial (solo se crea si no existe en la BD)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                       # OBLIGATORIO — mínimo 12 caracteres
ADMIN_EMAIL=admin@tudominio.com

# Email (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

PDF_STORAGE_PATH=./storage/invoices
UPLOAD_MAX_SIZE_MB=15

CORS_ORIGINS=http://127.0.0.1:8010,http://localhost:8010,http://127.0.0.1:8080,http://localhost:8080
